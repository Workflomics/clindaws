{
    "functions": [
        {
        "label": "init_sample",
        "id": "init_sample",
        "taxonomyOperations": ["init_sample"],
        "inputs": [
          { "Type": ["project_name"], "Format": ["str"] },
          { "Type": ["sample_name"], "Format": ["str"] },
          { "Type": ["fw_reads_path"], "Format": ["path"] },
          { "Type": ["rv_reads_path"], "Format": ["path"] }
        ],
        "outputs": [
          { "Type": ["rawdata_fw"], "Format": ["fastq"] },
          { "Type": ["rawdata_rv"], "Format": ["fastq"] }
        ],
        "implementation": {"code": "Scripts/init_sample.sh ${PROJECT} ${SAMPLE} FW RV\n"}
      },
      {
        "label": "fastqc_rawReads",
        "id": "fastqc_rawReads",
        "taxonomyOperations": ["fastqc_rawReads"],
        "inputs": [
          { "Type": ["rawdata_fw"], "Format": ["fastq"] },
          { "Type": ["rawdata_rv"], "Format": ["fastq"] }
        ],
        "outputs": [
          { "Type": ["fw_fastqc"], "Format": ["html"] },
          { "Type": ["rv_fastqc"], "Format": ["html"] },
          { "Type": ["fw_fastqc_summary"], "Format": ["txt"] },
          { "Type": ["rv_fastqc_summary"], "Format": ["txt"] }
        ],
        "implementation": {"code": "mkdir -p ${PROJECT}/samples/${SAMPLE}/qc\nfastqc ${PROJECT}/samples/${SAMPLE}/rawdata/fw.fastq.gz ${PROJECT}/samples/${SAMPLE}/rawdata/rv.fastq.gz --extract -t 4 -o ${PROJECT}/samples/${SAMPLE}/qc/\n"}
      },
      {
        "label": "validateQC",
        "id": "validateQC",
        "taxonomyOperations": ["validateQC"],
        "inputs": [
          { "Type": ["fw_fastqc_summary"], "Format": ["txt"] },
          { "Type": ["rv_fastqc_summary"], "Format": ["txt"] }
        ],
        "outputs": [
          { "Type": ["fq_fw_internal_validation"], "Format": ["txt"] },
          { "Type": ["fq_rv_internal_validation"], "Format": ["txt"] }
        ],
        "implementation": {"code": "python Scripts/validateQC.py ${PROJECT}/samples/${SAMPLE}/qc/fw_fastqc.html ${PROJECT}/samples/${SAMPLE}/qc/fq_fw_internal_validation.txt ${PROJECT}/samples/${SAMPLE}/rawdata/fw.fastq.gz ${PROJECT}/samples/${SAMPLE}/qc/fw_fastqc/summary.txt ${PROJECT}/samples/${SAMPLE}/qc/rv_fastqc.html ${PROJECT}/samples/${SAMPLE}/qc/fq_rv_internal_validation.txt ${PROJECT}/samples/${SAMPLE}/rawdata/rv.fastq.gz ${PROJECT}/samples/${SAMPLE}/qc/rv_fastqc/summary.txt\n"}
      },
      {
        "label": "trimmomatic",
        "id": "trimmomatic",
        "taxonomyOperations": ["trimmomatic"],
        "inputs": [
          { "Type": ["rawdata_fw"], "Format": ["fastq"] },
          { "Type": ["rawdata_rv"], "Format": ["fastq"] }
        ],
        "outputs": [
          { "Type": ["read1_paired"], "Format": ["fq"] },
          { "Type": ["read1_single"], "Format": ["fq"] },
          { "Type": ["read2_paired"], "Format": ["fq"] },
          { "Type": ["read2_single"], "Format": ["fq"] },
          { "Type": ["trimmomatic_log"], "Format": ["log"] }
        ],
        "implementation": {"code": "mkdir -p ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed\ntrimmomatic PE -threads 15 ${PROJECT}/samples/${SAMPLE}/rawdata/fw.fastq.gz ${PROJECT}/samples/${SAMPLE}/rawdata/rv.fastq.gz ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_paired.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_singles.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_paired.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_singles.fq ILLUMINACLIP:/export/lv5/software/anaconda/2022.05/envs/metacascabel_c_env/share/trimmomatic-0.39-2/adapters/TruSeq3-PE-2.fa:1:30:10:5:TRUE SLIDINGWINDOW:5:22 MAXINFO:40:0.6 MINLEN:100 > ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/trimmomatic.log 2>&1\n"}
      },
      {
        "label": "fastqc_trimmedReads",
        "id": "fastqc_trimmedReads",
        "taxonomyOperations": ["fastqc_trimmedReads"],
        "inputs": [
          { "Type": ["read1_paired"], "Format": ["fq"] },
          { "Type": ["read2_paired"], "Format": ["fq"] }
        ],
        "outputs": [
          { "Type": ["read1_paired_fastqc"], "Format": ["html"] },
          { "Type": ["read2_paired_fastqc"], "Format": ["html"] },
          { "Type": ["read1_paired_fastqc_summary"], "Format": ["txt"] },
          { "Type": ["read1_paired_fastqc_summary"], "Format": ["txt"] }
        ],
        "implementation": {"code": "mkdir -p ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/qc/\nfastqc ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_paired.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_paired.fq --extract -t 4 -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/qc/\n"}
      },
      {
        "label": "validateQC_trimmed",
        "id": "validateQC_trimmed",
        "taxonomyOperations": ["validateQC_trimmed"],
        "inputs": [
          { "Type": ["read1_paired_fastqc"], "Format": ["html"] },
          { "Type": ["read2_paired_fastqc"], "Format": ["html"] }
        ],
        "outputs": [
          { "Type": ["trimmed_fq_fw_internal_validation"], "Format": ["txt"] },
          { "Type": ["trimmed_fq_rv_internal_validation"], "Format": ["txt"] }
        ],
        "implementation": {"code": "python Scripts/validateQC.py ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/qc/read1_paired_fastqc.html ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/qc/fq_fw_internal_validation.txt ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_paired.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/qc/read1_paired_fastqc/summary.txt ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/qc/read2_paired_fastqc.html ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/qc/fq_rv_internal_validation.txt ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_paired.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/qc/read2_paired_fastqc/summary.txt\n"}
      },
      {
        "label": "kraken",
        "id": "kraken",
        "taxonomyOperations": ["kraken"],
        "inputs": [
          
          { "Type": ["rawdata_fw", "read1_paired"], "Format": ["fastq", "fq"] },
          { "Type": ["rawdata_rv", "read2_paired"], "Format": ["fastq", "fq"] }
        ],
        "outputs": [
