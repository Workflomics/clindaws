          { "Type": ["kraken_taxonomy"], "Format": ["tmp"] },
          { "Type": ["taxonomy_labels"], "Format": ["txt"] },
          { "Type": ["taxonomy_report"], "Format": ["txt"] }
        ],
        "implementation": {"code": "mkdir -p ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy\nkraken --preload --db /export/data01/databases/kraken/std_db/ --paired ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_paired.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_paired.fq --threads 30 > ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kraken.taxonomy.out\n#OR RAW\ncat ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kraken.taxonomy.out | cut -f1,2,3 > ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kraken.taxonomy.out.tmp\nkaiju-addTaxonNames -t /export/data01/databases/kraken/std_db/taxonomy/nodes.dmp -n /export/data01/databases/kraken/std_db/taxonomy/names.dmp -i ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kraken.taxonomy.out.tmp -r species  -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kraken.taxonomy.out.labels\nkaiju2table -t /export/data01/databases/kraken/std_db/taxonomy/nodes.dmp -n /export/data01/databases/kraken/std_db/taxonomy/names.dmp -r species  -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kraken.taxonomy.report ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kraken.taxonomy.out.labels\n"}
      },
      {
        "label": "kaiju",
        "id": "kaiju",
        "taxonomyOperations": ["kaiju"],
        "inputs": [
          { "Type": ["rawdata_fw", "read1_paired"], "Format": ["fastq", "fq"] },
          { "Type": ["rawdata_rv", "read2_paired"], "Format": ["fastq", "fq"] }
        ],
        "outputs": [
          { "Type": ["kaiju_taxonomy"], "Format": ["out"] },
          { "Type": ["taxonomy_labels"], "Format": ["txt"] },
          { "Type": ["taxonomy_report"], "Format": ["txt"] }
        ],
        "implementation": {"code": "mkdir -p ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy\nkaiju -i ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_paired.fq -j ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_paired.fq -t /export/data01/databases/kaiju/nodes.dmp  -f /export/data01/databases/kaiju/refseq/kaiju_db.fmi -z 30 -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kaiju.taxonomy.out\n#OR RAW\nkaiju-addTaxonNames -t /export/data01/databases/kaiju/nodes.dmp -n /export/data01/databases/kaiju/names.dmp -i ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kaiju.taxonomy.out.tmp -r species  -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kaiju.taxonomy.out.labels\nkaiju2table -t /export/data01/databases/kaiju/nodes.dmp -n /export/data01/databases/kaiju/names.dmp -r species  -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kaiju.taxonomy.report ${PROJECT}/runs/${RUN}/${SAMPLE}_data/taxonomy/kaiju.taxonomy.out.labels\n"}
      },
      {
        "label": "fq2fasta",
        "id": "fq2fasta",
        "taxonomyOperations": ["fq2fasta"],
        "inputs": [
          { "Type": ["read1_paired"], "Format": ["fq"] },
          { "Type": ["read2_paired"], "Format": ["fq"] }
        ],
        "outputs": [
          { "Type": ["reads_merged"], "Format": ["fasta"] }
        ],
        "implementation": {"code": "fq2fa --merge ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_paired.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_paired.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/reads_merged.fasta\n"}
      },
      {
        "label": "concat_single_reads",
        "id": "concat_single_reads",
        "taxonomyOperations": ["concat_single_reads"],
        "inputs": [
          { "Type": ["read1_single"], "Format": ["fq"] },
          { "Type": ["read2_single"], "Format": ["fq"] }
        ],
        "outputs": [
          { "Type": ["all_singles"], "Format": ["fq"] }
        ],
        "implementation": {"code": "cat ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_singles.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_singles.fq > ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/all_singles.fq\n"}
      },
      {
        "label": "meta_spades",
        "id": "meta_spades",
        "taxonomyOperations": ["meta_spades"],
        "inputs": [
          { "Type": ["read1_paired"], "Format": ["fq"] },
          { "Type": ["read2_paired"], "Format": ["fq"] },
          { "Type": ["all_singles"], "Format": ["fq"] }
        ],
        "outputs": [
          { "Type": ["contigs"], "Format": ["fasta"] },
          { "Type": ["scaffolds"], "Format": ["fasta"] }
        ],
        "implementation": {"code": "nice -5 spades.py --meta -t 35 -m 350 -k 21,33,55,77 --pe1-1 ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_paired.fq --pe1-2 ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_paired.fq --pe1-s ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/all_singles.fq -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/\n"}
      },
      {
        "label": "megahit",
        "id": "megahit",
        "taxonomyOperations": ["megahit"],
        "inputs": [
          { "Type": ["read1_paired"], "Format": ["fq"] },
          { "Type": ["read2_paired"], "Format": ["fq"] }
        ],
        "outputs": [
          { "Type": ["contigs_no_std_name"], "Format": ["fa"] }
        ],
        "implementation": {"code": "megahit -1 ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_paired.fq -2 ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_paired.fq -f --k-min 21 --k-max 141 --k-step 14 -m 0.3 -t 35 -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}\n"}
      },
      {
        "label": "std_assembly",
        "id": "std_assembly",
        "taxonomyOperations": ["std_assembly"],
        "inputs": [
          { "Type": ["contigs_no_std_name"], "Format": ["fasta", "fa"] }
        ],
        "outputs": [
          { "Type": ["contigs"], "Format": ["fasta"] },
          { "Type": ["scaffolds"], "Format": ["fasta"] }
        ],
        "implementation": {"code": "mv ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/final.contigs.fa ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.fasta && ln -sr ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.fasta ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/scaffolds.fasta\n# if idba: mv ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contig.fa ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.fasta && mv ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/scaffold.fa ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/scaffolds.fasta\n"}
      },
      {
        "label": "idba",
        "id": "idba",
        "taxonomyOperations": ["idba"],
        "inputs": [
          { "Type": ["reads_merged"], "Format": ["fasta"] }
        ],
        "outputs": [
          { "Type": ["contigs_no_std_name"], "Format": ["fa"] },
          { "Type": ["scaffolds_no_std_name"], "Format": ["fa"] }
        ],
        "implementation": {"code": "idba_ud -r ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/reads_merged.fasta -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/ --step 10 --num_threads 35\n"}
      },
      {
        "label": "quast",
        "id": "quast",
        "taxonomyOperations": ["quast"],
        "inputs": [
          { "Type": ["contigs"], "Format": ["fasta"] },
          { "Type": ["scaffolds"], "Format": ["fasta"] }
        ],
        "outputs": [
          { "Type": ["quast_lib_config"], "Format": ["txt"] },
          { "Type": ["contigs_report"], "Format": ["txt"] },
          { "Type": ["scaffolds_report"], "Format": ["txt"] }
        ],
        "implementation": {"code": "mkdir -p ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/quast\nexport PYTHONPATH=/opt/Downloads/biolinux/quast-4.6.3/ && touch ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/quast/quast_lib_config.txt\nquast.py -t 25 -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/quast/contigs/ ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.fasta\nquast.py -t 25 -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/quast/scaffolds/ -s ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/scaffolds.fasta\n"}
      },
      {
        "label": "split_assembly",
        "id": "split_assembly",
        "taxonomyOperations": ["split_assembly"],
        "inputs": [
          { "Type": ["contigs"], "Format": ["fasta"] }
        ],
        "outputs": [
          { "Type": ["split_flag"], "Format": ["txt"] },
          { "Type": ["contigs_complete"], "Format": ["fasta"] },
          { "Type": ["contigs"], "Format": ["fasta"] }
        ],
        "implementation": {"code": "/opt/biolinux/anaconda2.2019.07/bin/cut_up_fasta.py -c 10000 -o 0 -m ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.fasta > ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.chunks.fasta\nmv ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.fasta ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.complete.fasta && mv ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.chunks.fasta ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/contigs.fasta && echo \"contigs.fasta has been splitted by cut_up_fasta.py original contig file is: contigs.complete.fasta\" > ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/split_flag.txt\n"}
      },
      {
        "label": "validate_assembly",
        "id": "validate_assembly",
        "taxonomyOperations": ["validate_assembly"],
        "inputs": [
          { "Type": ["contigs_report"], "Format": ["txt"] },
          { "Type": ["scaffolds_report"], "Format": ["txt"] }
        ],
        "outputs": [
          { "Type": ["validate_assembly"], "Format": ["txt"] }
        ],
        "implementation": {"code": "python Scripts/validateQuast.py ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/quast/contigs/report.txt ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/quast/scaffolds/report.txt ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/quast/validate_assembly.txt\n"}
      },
      {
        "label": "mgm",
        "id": "mgm",
        "taxonomyOperations": ["mgm"],
        "inputs": [
          { "Type": ["contigs", "scaffolds"], "Format": ["fasta"] }
        ],
        "outputs": [
          { "Type": ["genes"], "Format": ["gff"] },
          { "Type": ["genes"], "Format": ["fasta"] },
          { "Type": ["prots"], "Format": ["fasta"] }
        ],
        "implementation": {"code": "mkdir -p ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/mgm_${ANALYSIS}\n/export/data/aabdala/utils/MetaGeneMark_linux_64/mgm/gmhmmp -a -d -f G -m /export/data/aabdala/utils/MetaGeneMark_linux_64/mgm/MetaGeneMark_v1.mod -A ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/mgm_${ANALYSIS}/genes.fasta -D ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/mgm_${ANALYSIS}/prots.fasta -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/mgm_${ANALYSIS}/genes.gff ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/${ANALYSIS}.fasta\n"}
      },
      {
        "label": "fgs",
        "id": "fgs",
        "taxonomyOperations": ["fgs"],
        "inputs": [
          { "Type": ["contigs", "scaffolds"], "Format": ["fasta"] }
