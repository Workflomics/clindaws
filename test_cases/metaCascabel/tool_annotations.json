        "outputs": [
          { "Type": ["genes"], "Format": ["gff"] },
          { "Type": ["genes"], "Format": ["ffn"] },
          { "Type": ["prots"], "Format": ["faa"] },
          { "Type": ["genes"], "Format": ["out"] }
        ],
        "implementation": {"code": "/export/data/aabdala/utils/FragGeneScan/run_FragGeneScan.pl -genome=${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/${ANALYSIS}.fasta -out=${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/fgs_${ANALYSIS}/genes -complete=0 -train=/export/data/aabdala/utils/FragGeneScan/train/complete -thread=4\n"}
      },
      {
        "label": "prodigal",
        "id": "prodigal",
        "taxonomyOperations": ["prodigal"],
        "inputs": [
          { "Type": ["contigs", "scaffolds"], "Format": ["fasta"] }
        ],
        "outputs": [
          { "Type": ["genes"], "Format": ["gff"] },
          { "Type": ["genes"], "Format": ["ffn"] },
          { "Type": ["prots"], "Format": ["faa"] }
        ],
        "implementation": {"code": "mkdir -p ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/prodigal_${ANALYSIS}\nprodigal -a ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/prodigal_${ANALYSIS}/genes.faa -d ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/prodigal_${ANALYSIS}/genes.ffn -f gff -i ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/${ANALYSIS}.fasta -p meta -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/prodigal_${ANALYSIS}/genes.gff\n"}
      },
      {
        "label": "bwa",
        "id": "bwa",
        "taxonomyOperations": ["bwa"],
        "inputs": [
          { "Type": ["contigs", "scaffolds"], "Format": ["fasta"] },
          { "Type": ["read1_paired"], "Format": ["fq"] },
          { "Type": ["read2_paired"], "Format": ["fq"] }
        ],
        "outputs": [
          { "Type": ["bwa_index"], "Format": ["bwt"] },
          { "Type": ["mapped_against_cross-assembly"], "Format": ["bam"] }
        ],
        "implementation": {"code": "mkdir -p ${PROJECT}/runs/${RUN}/${SAMPLE}_data/bwa-mem/${ANALYSIS}_${ASSEMBLER}_assembly\nbwa index -p ${PROJECT}/runs/${RUN}/${SAMPLE}_data/bwa-mem/${ANALYSIS}_${ASSEMBLER}_assembly ${PROJECT}/runs/${RUN}/${SAMPLE}_data/assembly_${ASSEMBLER}/${ANALYSIS}.fasta\nnice -5 bwa mem -t 15 ${PROJECT}/runs/${RUN}/${SAMPLE}_data/bwa-mem/${ANALYSIS}_${ASSEMBLER}_assembly ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read1_paired.fq ${PROJECT}/runs/${RUN}/${SAMPLE}_data/trimmed/read2_paired.fq | samtools view --threads 15 -b - | samtools sort - -o ${PROJECT}/runs/${RUN}/${SAMPLE}_data/bwa-mem/${ANALYSIS}_${ASSEMBLER}_mapped_against_cross-assembly_sorted.bam --threads 15\n"}
      },
      {
        "label": "sam_flags",
        "id": "sam_flags",
        "taxonomyOperations": ["sam_flags"],
        "inputs": [
          { "Type": ["mapped_against_cross-assembly"], "Format": ["bam"] }
        ],
        "outputs": [
          { "Type": ["mapped_against_cross-assembly"], "Format": ["flagstat"] }
        ],
        "implementation": {"code": "samtools flagstat --threads 15 ${PROJECT}/runs/${RUN}/${SAMPLE}_data/bwa-mem/${ANALYSIS}_${ASSEMBLER}_mapped_against_cross-assembly_sorted.bam > ${PROJECT}/runs/${RUN}/${SAMPLE}_data/bwa-mem/${ANALYSIS}_${ASSEMBLER}_mapped_against_cross-assembly_sorted.flagstat\n"}
      },
      {
        "label": "summarize_bam",
